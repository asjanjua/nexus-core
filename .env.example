# ============================================================
# NexusAI Mission Control - Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# App
NEXT_PUBLIC_APP_NAME=NexusAI Mission Control
NEXT_PUBLIC_NEXUS_ENV=pilot
NEXUS_ENV=development
NEXUS_DEMO_WORKSPACE=workspace-demo
NEXUS_SLACK_WORKSPACE=workspace-demo
# Slack connector ingestion is off unless a channel is allowlisted or this
# explicit override is enabled. Prefer SLACK_INGEST_CHANNELS in production.
SLACK_INGEST_CHANNELS=
NEXUS_SLACK_INGEST_ALL=disabled

# ============================================================
# Clerk Authentication (replaces custom session auth)
# Get these from dashboard.clerk.com -> your app -> API Keys
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk routing — where to send users for sign-in.
# After-auth redirects are set through ClerkProvider fallbackRedirectUrl props
# in apps/mission-control/app/layout.tsx. Do not set legacy
# NEXT_PUBLIC_CLERK_AFTER_* env vars; Clerk warns about them in production.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook signing secret (Dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_replace_me

# ============================================================
# Legacy — kept for agent Bearer token signing only
# (Clerk handles user session auth; this signs agent API tokens)
# ============================================================
AUTH_SECRET=replace_me_with_64_char_random_string

# Database (optional in dev - falls back to in-memory store)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexus
NEXUS_DB_REQUIRED=false

# ============================================================
# LLM Provider - set ONE of these
# ============================================================

# Option 1: DeepSeek paid API (recommended for Nexus cost-aware agent runs)
NEXUS_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
NEXUS_LLM_MODEL=deepseek-v4-pro

# Basic LLM guardrails. Tune per pilot workspace and budget.
NEXUS_LLM_MAX_REQUESTS_PER_MINUTE=30
NEXUS_LLM_DAILY_TOKEN_BUDGET=250000
NEXUS_LLM_MAX_PROMPT_CHARS=80000

# Option 2: Anthropic Claude
ANTHROPIC_API_KEY=replace_me
# NEXUS_LLM_PROVIDER=anthropic
# NEXUS_LLM_MODEL=claude-opus-4-6
# Optional: route Anthropic traffic through Cloudflare AI Gateway
# Example:
# ANTHROPIC_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway_id>/anthropic
# Optional if your gateway requires authenticated access:
# CLOUDFLARE_AI_GATEWAY_TOKEN=replace_me

# Option 3: OpenAI GPT
# OPENAI_API_KEY=replace_me
# NEXUS_LLM_MODEL=gpt-4o

# Option 4: Azure OpenAI
# AZURE_OPENAI_API_KEY=replace_me
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ============================================================
# App URL (used for OAuth redirect URIs)
# ============================================================
# Production demo domain example:
# NEXT_PUBLIC_APP_URL=https://app.pinavia.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated cutover allowlist for API CORS while both the
# Render URL and custom domain are in use.
# NEXUS_EXTRA_CORS_ORIGINS=https://nexus-mission-control.onrender.com

# Protected endpoint secret for scheduled synthesis cron runners.
# Used by POST {NEXT_PUBLIC_APP_URL}/api/cron/synthesis.
NEXUS_CRON_SECRET=replace_me_with_32_char_random_string

# ============================================================
# Product email delivery
# Clerk owns auth email: signup/signin verification, password
# reset, and account lifecycle messages. Nexus only sends product
# email such as scheduled synthesis briefs and pilot notifications.
# Authenticate the sending domain before using this in production.
# ============================================================
NEXUS_RESEND_API_KEY=replace_me
NEXUS_FROM_EMAIL="Nexus <noreply@pinavia.io>"
# Outside pilot/production (NEXUS_ENV), sends are refused unless the recipient
# matches this comma-separated list of addresses or @domains.
NEXUS_EMAIL_ALLOWLIST="ali.janjua@live.com,@pinavia.io"

# ============================================================
# Slack integration
# Bot token scopes: channels:history, channels:read, groups:history,
#                   groups:read, users:read, files:read
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/connectors/slack/callback
# ============================================================
SLACK_CLIENT_ID=replace_me
SLACK_CLIENT_SECRET=replace_me
SLACK_SIGNING_SECRET=replace_me
SLACK_BOT_TOKEN=replace_me
SLACK_APP_TOKEN=replace_me

# ============================================================
# Object storage (for future connector expansion)
# ============================================================
OBJECT_STORAGE_BUCKET=nexus-evidence

# ============================================================
# Cloudflare R2 original file retention (optional)
# Keeps original uploaded files for provenance and re-review.
# ============================================================
# Set to enabled to store originals in R2 during ingestion.
NEXUS_R2_ORIGINALS=disabled
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=nexus-evidence

# ============================================================
# Stripe (Billing Tiers v0.21.0)
# Get from dashboard.stripe.com -> Developers -> API Keys
# ============================================================
# Secret key (server-side only, never expose to client)
STRIPE_SECRET_KEY=sk_test_replace_me

# Webhook signing secret (Dashboard -> Webhooks -> your endpoint -> Signing Secret)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs for each plan (Dashboard -> Products -> your product -> Prices)
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_BUSINESS=price_replace_me

# App URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
